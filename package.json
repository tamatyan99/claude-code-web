{
  "name": "claude-code-web",
  "version": "3.4.0",
  "description": "Web-based chat interface for Claude Code CLI with structured JSON output, multi-session support, and mobile optimization",
  "main": "src/server.js",
  "bin": {
    "cc-web": "./bin/cc-web.js"
  },
  "scripts": {
    "start": "node bin/cc-web.js",
    "dev": "node bin/cc-web.js --dev",
    "test": "mocha test/*.test.js",
    "release:pr": "bash scripts/release-pr.sh"
  },
  "keywords": [
    "claude",
    "claude-code",
    "web",

    "browser",
    "remote",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.92",
    "@ngrok/ngrok": "^1.4.0",
    "commander": "^12.1.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",

    "open": "^10.1.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vultuk/claude-code-web.git"
  },
  "homepage": "https://github.com/vultuk/claude-code-web#readme",
  "devDependencies": {
    "mocha": "^11.3.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
